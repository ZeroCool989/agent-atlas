---
/**
 * Search (plan §12: Pagefind, build-time static index, zero server). The index is generated
 * into /pagefind/ by `npm run build` and queried entirely in the browser. Without JavaScript
 * there is no live search, so we offer an honest fallback: browse the concept reference.
 */
import SearchBox from '../components/SearchBox';
import Base from '../layouts/Base.astro';
---

<Base
  title="Search"
  description="Search every concept, playground, and governance page in the atlas."
>
  <main id="main" class="mx-auto max-w-3xl space-y-6 px-6 py-12">
    <header class="space-y-2">
      <h1 class="text-3xl font-bold tracking-tight">Search</h1>
      <p class="text-slate-600">
        Full-text search across concepts, playgrounds, and governance. The index is static and
        the search runs in your browser — nothing is sent anywhere.
      </p>
    </header>

    <SearchBox client:load />

    <noscript>
      <p class="rounded border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600">
        Search needs JavaScript. You can still browse everything from the{' '}
        <a href="/concepts" class="underline">concept reference</a> or the{' '}
        <a href="/" class="underline">atlas graph</a>.
      </p>
    </noscript>
  </main>
</Base>
