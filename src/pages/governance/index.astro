---
/**
 * Governance index: every framework in the atlas — what it is, who it binds, whether it is
 * binding, and how many concepts it touches. Governance is a layer on the map, not a
 * separate site (plan §10): each framework links to its page and to the mapping matrix.
 * Zero client JS.
 */
import { getCollection } from 'astro:content';

import Base from '../../layouts/Base.astro';
import { conceptsForFramework } from '../../lib/governance/links';

const [concepts, frameworks] = await Promise.all([
  getCollection('concepts'),
  getCollection('governance'),
]);
const govConcepts = concepts.map((c) => ({ id: c.id, governance: c.data.governance }));
const govFrameworks = frameworks.map((f) => ({ id: f.id, appliesTo: f.data.appliesTo }));

const rows = frameworks
  .map((f) => ({
    id: f.id,
    title: f.data.title,
    kind: f.data.kind,
    binding: f.data.binding,
    oneLiner: f.data.oneLiner,
    bindsWho: f.data.bindsWho,
    count: conceptsForFramework(f.id, govConcepts, govFrameworks).length,
  }))
  // binding instruments first, then by title
  .sort((a, b) => Number(b.binding ?? false) - Number(a.binding ?? false) || (a.title < b.title ? -1 : 1));
---

<Base title="Governance" description="The regulations, standards, and security guidance that touch AI systems — each mapped to the technical concepts it reaches.">
  <main id="main" class="mx-auto max-w-3xl space-y-8 px-6 py-12">
    <header class="space-y-2">
      <h1 class="text-3xl font-bold tracking-tight">Governance</h1>
      <p class="text-slate-600">
        Governance is a layer on the map, not a separate site. Each framework below links to
        the technical concepts it reaches — a rule only matters once you can see the mechanism
        it governs. Connections mean potential relevance, not that a framework necessarily
        applies.
      </p>
      <p class="text-sm">
        <a href="/governance/matrix" class="underline">Open the concept × regulation matrix →</a>
      </p>
    </header>

    <ul class="space-y-4">
      {
        rows.map((f) => (
          <li class="rounded border border-slate-200 p-4">
            <div class="flex flex-wrap items-baseline justify-between gap-2">
              <a href={`/governance/${f.id}`} class="text-lg font-semibold underline">
                {f.title}
              </a>
              <div class="flex gap-2 text-xs">
                {f.kind && <span class="rounded bg-slate-100 px-2 py-0.5 font-medium text-slate-700">{f.kind}</span>}
                <span class="rounded bg-slate-100 px-2 py-0.5 font-medium text-slate-700">
                  {f.binding === true ? 'binding' : f.binding === false ? 'voluntary' : 'mixed'}
                </span>
                <span class="text-slate-500">{f.count} concept{f.count === 1 ? '' : 's'}</span>
              </div>
            </div>
            {f.oneLiner && <p class="mt-1 text-sm text-slate-600">{f.oneLiner}</p>}
            {f.bindsWho && <p class="mt-1 text-xs text-slate-500">Binds: {f.bindsWho}</p>}
          </li>
        ))
      }
    </ul>
  </main>
</Base>
