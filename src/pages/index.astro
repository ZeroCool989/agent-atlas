---
import Base from '../layouts/Base.astro';
---

<Base title="Atlas">
  <main class="mx-auto max-w-2xl px-6 py-24">
    <h1 class="text-4xl font-bold tracking-tight">Agent Atlas</h1>
    <p class="mt-4 text-lg text-slate-600">
      An interactive atlas of modern AI systems — from tokens to multi-agent systems to
      the governance that regulates them.
    </p>
    <p class="mt-8 text-sm text-slate-400">Phase 0 · under construction</p>
  </main>
</Base>
