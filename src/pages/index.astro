---
/**
 * The Atlas home — the signature surface (plan §4). The concept knowledge graph, derived
 * from the content collection and positioned by essentiality layer (foundations centre →
 * vendor-specific rim). The layout is computed at build time by the pure
 * `computeGraphLayout`, so the graph is server-rendered (usable without JavaScript) and
 * hydrates to add the local progress overlay and focus/hover detail. Entry points to the
 * concept reference sit below the map.
 */
import { getCollection } from 'astro:content';

import AtlasGraph from '../components/AtlasGraph';
import Base from '../layouts/Base.astro';
import { computeGraphLayout, type LayoutConceptInput } from '../lib/graph/layout';

const concepts = await getCollection('concepts');
const layoutInput: LayoutConceptInput[] = concepts.map((c) => ({
  slug: c.id,
  label: c.data.title,
  layer: c.data.layer,
  status: c.data.status,
  oneLiner: c.data.oneLiner,
  prerequisites: c.data.prerequisites ?? [],
  related: c.data.related ?? [],
}));
const layout = computeGraphLayout(layoutInput, { width: 960, height: 720 });

const complete = concepts.filter((c) => c.data.status === 'complete').length;
---

<Base
  title="Atlas"
  description="An interactive atlas of modern AI systems — from tokens to multi-agent systems to the governance that regulates them. Concepts are positioned by how essential they are: foundations at the centre, vendor-specific at the rim."
>
  <main id="main" class="mx-auto max-w-5xl px-6 py-12">
    <header class="mx-auto max-w-2xl text-center">
      <h1 class="text-4xl font-bold tracking-tight text-slate-900">Agent Atlas</h1>
      <p class="mt-4 text-lg text-slate-600">
        How AI systems actually work — from tokens to multi-agent systems to the governance
        that regulates them. Every concept is placed by how essential it is:
        <span class="font-medium">foundations at the centre, vendor-specific at the rim.</span>
      </p>
      <p class="mt-3 text-sm text-slate-400">
        {complete} concepts mapped and explained · more on the way
      </p>
    </header>

    <section class="mt-10" aria-label="The atlas">
      <AtlasGraph layout={layout} client:load />
    </section>

    <nav class="mx-auto mt-10 flex max-w-md flex-col items-center gap-3 sm:flex-row sm:justify-center">
      <a
        href="/concepts"
        class="w-full rounded-lg bg-slate-900 px-5 py-2.5 text-center text-sm font-medium text-white hover:bg-slate-700 sm:w-auto"
        >Browse all concepts</a
      >
      <a
        href="/experiments"
        class="w-full rounded-lg border border-slate-300 px-5 py-2.5 text-center text-sm font-medium text-slate-700 hover:bg-slate-100 sm:w-auto"
        >See the experiments</a
      >
    </nav>
  </main>
</Base>
