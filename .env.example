# Real-model experiment keys (LOCAL ONLY — see docs/DEPLOYMENT.md, ADR-0005).
# Copy to .env (git-ignored) and fill in the providers you want to run.
# The deployed public site NEVER reads these; experiments are developer tools.
# Any matrix row whose key is absent is SKIPPED with a visible reason — the
# framework runs end-to-end (scripted rows) with none of these set.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# OpenAI-compatible servers (Qwen, Llama, Mistral, DeepSeek, local): set the key here
# and the base URL in the env var named by the definition's `baseUrlEnv`. Example:
OPENAI_COMPATIBLE_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
